# --- Build outputs -------------------------------------------------------
# The default Qt .gitignore above misses CMake build trees.
build/
build-*/
out/
cmake-build-*/

# CMake leftovers if they ever leak to the source tree
CMakeCache.txt
CMakeFiles/
CMakeUserPresets.json
.cmake/

# Qt Creator scratch dir created next to CMakeLists.txt
.qtcreator/

# VS Code: keep shared configs, ignore per-user state
.vscode/*
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/settings.json
!.vscode/extensions.json

# OS clutter
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# Editor swap / backup
*.swp
*.swo
*~
*.bak
*.orig

# Runtime log written next to the .exe
autolabel.log

