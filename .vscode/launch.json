{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Qt Application",
            "type": "cppdbg",
            "request": "launch",
            "program": "${command:cmake.launchTargetPath}",
            "args": [],
            "stopAtEntry": false,
            "preLaunchTask": "CMake: build",
            "cwd": "${workspaceFolder}",
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "windows": {
                "miDebuggerPath": "C:\\Qt\\Tools\\mingw1310_64\\bin\\gdb.exe",
                "environment": [
                    {
                        "name": "PATH",
                        "value": "C:\\Qt\\6.11.1\\mingw_64\\bin;C:\\Qt\\Tools\\mingw1310_64\\bin;${env:PATH}"
                    },
                    {
                        "name": "QT_PLUGIN_PATH",
                        "value": "C:\\Qt\\6.11.1\\mingw_64\\plugins"
                    }
                ]
            },
            "linux": {
                "miDebuggerPath": "/usr/bin/gdb",
                "environment": [
                    {
                        "name": "LD_LIBRARY_PATH",
                        "value": "${env:HOME}/Qt/6.11.1/gcc_64/lib:${env:LD_LIBRARY_PATH}"
                    },
                    {
                        "name": "QT_PLUGIN_PATH",
                        "value": "${env:HOME}/Qt/6.11.1/gcc_64/plugins"
                    }
                ]
            }
        }
    ]
}
